{
  "name": "pawliz-backend",
  "version": "1.0.0",
  "description": "Pawliz - Veterinary Platform Backend",
  "main": "dist/server.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch server.ts",
    "seed": "tsx database/seed.ts",
    "test": "jest",
    "migrate": "tsx migrate.ts up",
    "migrate:prod": "node dist/migrate.js up",
    "migrate:down": "tsx migrate.ts down",
    "migrate:status": "tsx migrate.ts status",
    "migrate:create": "tsx migrate.ts create"
  },
  "node-pg-migrate": {
    "migrations-dir": "migrations",
    "database-url-var": "DATABASE_URL"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.[jt]s"],
    "testTimeout": 15000,
    "transform": {
      "^.+\\.[jt]s$": ["ts-jest", { "tsconfig": "tsconfig.test.json" }]
    }
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1058.0",
    "@aws-sdk/s3-request-presigner": "^3.1058.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.4.1",
    "express-validator": "^7.0.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.0.0",
    "node-cron": "^4.2.1",
    "pg": "^8.11.3",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "node-pg-migrate": "^8.0.4",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
